 */
import java.util.Scanner;
public class TinhLuong {

	/**
	 * @param args
	 */
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		 Scanner sc = new Scanner(System.in);

	        System.out.print("Nhập số giờ làm: ");
	        double gioLam = sc.nextDouble();

	        System.out.print("Nhập lương theo giờ: ");
	        double luongGio = sc.nextDouble();

	        double tongLuong;

	        if (gioLam > 40) {
	            double gioThuong = 40;
	            double gioTangCa = gioLam - 40;
	            tongLuong = (gioThuong * luongGio) + (gioTangCa * luongGio * 1.5);
	        } else {
	            tongLuong = gioLam * luongGio;
	        }

	        System.out.println("Tổng lương: " + tongLuong);

	}

}
